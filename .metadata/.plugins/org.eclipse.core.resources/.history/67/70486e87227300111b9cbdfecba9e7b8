package com.rovira.setterInjection;

public class Employee
{
	Integer yearOfExperience;
	Department department;
	
	public void setYearOfExperience(Integer yearOfExperience)
	{
		this.yearOfExperience = yearOfExperience;
	}
	
	public void setDepartment(Department department)
	{
		this.department = department;
	}
	
	
	public void employeeDatails()
	{
		System.out.println("Experience: "+this.yearOfExperience);
		System.out.println("Departmant id: "+this.department.departmentId);
		System.out.println("Departmant : "+this.department.departmentName);
	}
}