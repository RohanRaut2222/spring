<?xml version="1.0" encoding="UTF-8"?>
<beans xmlns="http://www.springframework.org/schema/beans"
    xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
    xsi:schemaLocation="
        http://www.springframework.org/schema/beans http://www.springframework.org/schema/beans/spring-beans.xsd">

    <!-- bean definitions here -->


	
	<bean id="employee" name="com.rovira.setterInjection.Employee">
		<property name="yearOfExperience" value="2"/>
		<property name="department" ref="department"/>
	</bean>
	
		<bean id="department" name="com.rovira.setterInjection.Department">
		<property name="departmentId" value="001"/>
		<property name="departmentName" value="IT"/>
	</bean>
</beans>